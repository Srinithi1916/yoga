MONGODB_URI=mongodb://localhost:27017/jeevanam360
# If mongodb+srv DNS lookups fail locally, use the direct Atlas host format instead:
# MONGODB_URI=mongodb://USERNAME:PASSWORD@ac-xxxxx-shard-00-00.example.mongodb.net:27017,ac-xxxxx-shard-00-01.example.mongodb.net:27017,ac-xxxxx-shard-00-02.example.mongodb.net:27017/jeevanam360?ssl=true&authSource=admin&replicaSet=atlas-xxxxxx-shard-0&retryWrites=true&w=majority&appName=Cluster0
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://*.netlify.app,https://jeevanam360a.netlify.app
SERVER_PORT=8080
JWT_SECRET=change-this-jwt-secret-for-production
JWT_EXPIRATION_HOURS=72

# Frontend EmailJS handles contact email sending now.
# These mail settings are optional unless you switch back to backend SMTP later.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-email@gmail.com
CONTACT_RECEIVER_EMAIL=contact@example.com
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_STARTTLS_REQUIRED=true
MAIL_SMTP_SSL_TRUST=smtp.gmail.com
MAIL_BRAND_NAME=Jeevanam 360

RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your_secret_here


APP_ADMIN_EMAILS=admin@example.com
APP_ADMIN_BOOTSTRAP_PASSWORD=change-admin-password
APP_ADMIN_NAME=Jeevanam 360 Admin
APP_ADMIN_PHONE=
